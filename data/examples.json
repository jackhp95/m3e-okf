  "theme": [
    {
      "title": "Theme with drawer, nav menu, and app bar shell",
      "code": "<m3e-theme color=\"#8B6F47\" scheme=\"auto\" contrast=\"standard\" motion=\"expressive\" strong-focus>\n  <m3e-drawer-container start-mode=\"over\">\n    <nav slot=\"start\">\n      <m3e-nav-menu>\n        <a href=\"/photos\">\n          <m3e-nav-menu-item selected>\n            <m3e-icon slot=\"icon\" name=\"photo_library\"></m3e-icon>\n            <span slot=\"label\">Photos</span>\n          </m3e-nav-menu-item>\n        </a>\n      </m3e-nav-menu>\n    </nav>\n    <m3e-app-bar>\n      <m3e-icon-button slot=\"leading\" aria-label=\"Back\">\n        <m3e-icon name=\"arrow_back\"></m3e-icon>\n      </m3e-icon-button>\n      <span slot=\"title\">Title</span>\n    </m3e-app-bar>\n  </m3e-drawer-container>\n</m3e-theme>",
